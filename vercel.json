{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/admin.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/micro-families",
      "destination": "/admin.html"
    }
  ],
  "crons": [
    {
      "path": "/api/scanner/run",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/trade/run",
      "schedule": "*/2 * * * *"
    }
  ]
}