{
  "version": 2,
  "regions": ["ams1"],
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": ".next",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron-bull",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron-bear",
      "schedule": "*/30 * * * *"
    }
  ]
}