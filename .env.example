# =========================
# MAIN FUNNEL / TRADE SYSTEM
# =========================

# Required secrets (API access + cron)
API_SECRET=change-me-super-secret
CRON_SECRET=change-me-cron-secret

# =========================
# Vercel KV (required)
# =========================
# If you use @vercel/kv, Vercel will typically inject these automatically in production.
# For local dev, provide them (get from Vercel KV dashboard).
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# =========================
# Discord (required for alerts)
# =========================
# Create a Discord webhook URL in your Discord server/channel settings.
DISCORD_WEBHOOK_URL=

# Optional: extra routing / tagging
DISCORD_WEBHOOK_USERNAME=MainFunnelBot
DISCORD_WEBHOOK_AVATAR_URL=
DISCORD_DEFAULT_CHANNEL=main-funnel

# =========================
# Exchange Execution (Bitget) — REQUIRED for real orders
# =========================
# WARNING: These are powerful credentials. Use API keys with minimal permissions.
# For SPOT trading, ensure your key is enabled for spot trading and (if needed) IP whitelist allows Vercel IPs (usually not practical).
# Prefer using sub-account keys and low limits.

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# Which environment to use for execution:
# - "live"   => real trading
# - "paper"  => no orders placed (simulated)
EXECUTION_MODE=paper

# Optional: default symbol suffix for spot pairs
EXECUTION_QUOTE=USDT

# =========================
# Risk / sizing (optional)
# =========================
BASE_POSITION_SIZE_USD=50
MAX_OPEN_TRADES=6

# =========================
# Misc / Diagnostics (optional)
# =========================
NODE_ENV=production
LOG_LEVEL=info