{
  "_fileTitle": "package.json",
  "name": "clean-micro-trading-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scanner:run": "node scripts/runScanner.js",
    "trade:run": "node scripts/runTradeSystem.js",
    "analyze:freeze": "node scripts/freezeWeekly.js",
    "analyze:activate": "node scripts/activateRotation.js",
    "trace:scanner": "node --trace-deprecation scripts/runScanner.js",
    "trace:trade": "node --trace-deprecation scripts/runTradeSystem.js",
    "check:node": "node -v",
    "check:syntax": "bash -lc 'set -e; files=$(find src api scripts -name \"*.js\" -type f | sort); for file in $files; do echo \"CHECKING_SYNTAX:$file\"; if ! output=$(node --check \"$file\" 2>&1); then echo \"SYNTAX_FAILED_IN:$file\"; echo \"$output\"; exit 1; fi; done; echo \"SYNTAX_OK\"'",
    "build": "npm run check:syntax"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3"
  },
  "engines": {
    "node": "20.x"
  }
}